# Trading Bot Pro - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (PostgreSQL) - REQUIRED
# ===========================================
DATABASE_URL="postgresql://username:password@localhost:5432/trading_bot"

# ===========================================
# NEXTAUTH (Authentication)
# ===========================================
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://your-domain.com:3000"

# ===========================================
# IB CONNECTION SETTINGS
# ===========================================
IB_HOST="127.0.0.1"
IB_PORT="7497"
IB_CLIENT_ID="1"

# ===========================================
# TELEGRAM NOTIFICATIONS (Optional)
# ===========================================
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ===========================================
# TRADING MODE (IMPORTANT!)
# ===========================================
# SIMULATION: Test only, no real trades, fake data allowed
# PAPER: Paper trading on IB TWS, real data required
# LIVE: Real trading on IB TWS, real data required
TRADING_MODE="PAPER"

# ===========================================
# TRADING SETTINGS
# ===========================================
DEFAULT_QUANTITY="1"
MAX_RISK_PER_TRADE="100"
DEFAULT_EXPIRY="0DTE"

# ===========================================
# SERVER SETTINGS
# ===========================================
PORT="3000"
HOSTNAME="0.0.0.0"
NODE_ENV="production"
